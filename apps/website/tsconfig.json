{
	"extends": "astro/tsconfigs/strict",
	"include": [".astro/types.d.ts", "**/*"],
	"exclude": ["dist"],
	"compilerOptions": {
		"paths": {
			"@assets/*": ["./src/assets/*"],
			"@components/*": ["./src/components/*"],
			"@styles/*": ["./src/styles/*"],
			"@data/*": ["./src/data/*"],
			"@layouts/*": ["./src/layouts/*"],
			"@utils/*": ["./src/utils/*"],
			"@hooks/*": ["./src/hooks/*"],
			"@scripts/*": ["./src/scripts/*"],
			"@pageTypes/*": ["./src/pageTypes/*"],
			"@store/*": ["./src/store/*"]
		},
		"jsx": "react-jsx",
		"jsxImportSource": "react"
	}
}
